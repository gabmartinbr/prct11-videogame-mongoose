{
  "compilerOptions": {
    "target": "es2024",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["esnext"],
    "rootDir": "./",
    "outDir": "./dist",
    "types": ["node", "vitest/globals"], 
    "esModuleInterop": true, 
    "skipLibCheck": true,
    "declaration": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vitest.config.ts",
    "eslint.config.mjs"
  ]
}